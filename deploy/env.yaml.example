# Runtime environment for the Cloud Run Job. Copy to deploy/env.yaml and fill in.
# deploy/env.yaml is gitignored — it holds your secrets.

# --- Data source ---
DATA_PROVIDER: "fmp"          # sample | fmp | finnhub | stockwatcher
FMP_API_KEY: "your-free-fmp-key"
# FINNHUB_API_KEY: ""
# FINNHUB_SYMBOLS: "AAPL,NVDA,TSLA,MSFT,GOOGL"

# --- Watchlist / rules ---
WATCH_POLITICIANS: "Nancy Pelosi,Dan Crenshaw,Tommy Tuberville"
TRADE_TYPES: "both"           # buy | sell | both
MIN_TRADE_VALUE: "0"

# --- Cloud state (set by deploy.sh to your bucket) ---
STATE_BUCKET: "REPLACED_BY_DEPLOY_SCRIPT"

# --- Email (Gmail App Password) ---
EMAIL_ENABLED: "true"
SMTP_HOST: "smtp.gmail.com"
SMTP_PORT: "587"
SMTP_USER: "youraddress@gmail.com"
SMTP_PASS: "your-16-char-app-password"
EMAIL_FROM: "youraddress@gmail.com"
EMAIL_TO: "youraddress@gmail.com"

# --- SMS (Twilio) -> texts your phone ---
SMS_ENABLED: "true"
TWILIO_ACCOUNT_SID: "ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN: "your-twilio-auth-token"
TWILIO_FROM: "+1XXXXXXXXXX"    # your Twilio number
SMS_TO: "+18564440212"          # your phone
