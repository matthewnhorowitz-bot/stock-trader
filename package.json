  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "nodemailer": "^6.9.14",
    "twilio": "^5.2.2"
  },
  "optionalDependencies": {
    "@google-cloud/storage": "^7.12.0"
  }
}
