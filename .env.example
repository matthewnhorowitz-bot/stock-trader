# ─── Data source ───────────────────────────────────────────────────────────────
# Where to pull congressional trades from:
#   official     Senate eFD + House Clerk (real-time, no key/quota; falls back to FMP)
#   sample       (default) bundled offline data — runs with zero setup
#   fmp          Financial Modeling Prep   (set FMP_API_KEY — free tier)
#   finnhub      Finnhub                   (set FINNHUB_API_KEY + FINNHUB_SYMBOLS)
#   stockwatcher legacy free S3 buckets    (no key, but often access-locked / 403)
DATA_PROVIDER=sample

# Get a free key at https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# Get a free key at https://finnhub.io/dashboard . Finnhub queries per-ticker,
# so list the symbols you care about:
FINNHUB_API_KEY=
FINNHUB_SYMBOLS=AAPL,NVDA,TSLA,MSFT,GOOGL

# Tiingo EOD (free key at https://www.tiingo.com). Retains delisted/acquired-company
# history that Yahoo purges, so the performance index can price bought-out tickers
# (Whole Foods, LinkedIn, etc.) instead of dropping them. Used only as a fallback
# when Yahoo returns no data.
TIINGO_API_KEY=

# ─── Legislative source (Divergence / Hypocrisy Score) ──────────────────────────
# Where to pull votes + (co-)sponsorships from, used to score how a member's votes
# diverge from their portfolio (`npm run divergence`):
#   sample      (default) bundled data/sample_votes.json — runs with zero setup
#   congressgov live Congress.gov feed (future; set CONGRESS_API_KEY) — currently
#               falls back to sample
VOTES_PROVIDER=sample
# Free key from https://api.congress.gov/sign-up/ (required for VOTES_PROVIDER=congressgov).
CONGRESS_API_KEY=
# Live-feed bounds (warms over runs, like sector data): members fetched per run and
# how many recent House roll-call votes to scan per run.
CONGRESS_MEMBER_MAX=25
CONGRESS_VOTE_MAX=40

# ─── Watchlist ────────────────────────────────────────────────────────────────
# Comma-separated legislator names to follow. Leave BLANK to follow everyone.
# Matching is case-insensitive and partial ("pelosi" matches "Nancy Pelosi").
WATCH_POLITICIANS=Nancy Pelosi,Dan Crenshaw,Tommy Tuberville

# Which trade types trigger an alert: buy | sell | both
TRADE_TYPES=both

# Ignore trades whose reported value is below this dollar amount (uses the LOW
# end of the disclosed range). 0 = no minimum.
MIN_TRADE_VALUE=0

# End-of-month digest: a trade counts as "major" if the high end of its disclosed
# range is at least this amount. Default 100000 ($100k+).
MONTHLY_REPORT_MIN_VALUE=100000

# How often to poll, in minutes.
POLL_INTERVAL_MINUTES=30

# ─── Email (via Gmail SMTP) ─────────────────────────────────────────────────────
# Leave EMAIL_TO blank to disable email alerts.
# For Gmail, create an App Password: https://myaccount.google.com/apppasswords
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=youraddress@gmail.com
EMAIL_TO=youraddress@gmail.com

# ─── SMS (via Twilio) ──────────────────────────────────────────────────────────
# Leave SMS_ENABLED=false to disable. Sign up free at https://twilio.com
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM=+15551234567
SMS_TO=+18564440212

# ─── Free "text" via carrier email-to-SMS gateway ───────────────────────────────
# A free alternative to Twilio: emails the alert to your carrier's SMS gateway,
# which delivers it to your phone as a text. Needs SMTP_USER/SMTP_PASS above.
#   Verizon: <num>@vtext.com   AT&T: <num>@txt.att.net   T-Mobile: <num>@tmomail.net
#   Google Fi: <num>@msg.fi.google.com   US Cellular: <num>@email.uscc.net
SMS_VIA_EMAIL=false
SMS_EMAIL_ADDRESS=

# ─── Cloud state (Cloud Run only) ────────────────────────────────────────────
# Leave BLANK for local runs (uses ./data). On Cloud Run, set this to a Google
# Cloud Storage bucket name so dedup state survives between scheduled runs.
STATE_BUCKET=
